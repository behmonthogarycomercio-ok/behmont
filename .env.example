# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx   # server-only, never exposed to the client

# ── WhatsApp (destino de los pedidos) ────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=5493xxxxxxxxx   # formato internacional sin +

# ── MercadoLibre (API oficial) ───────────────────────────
# Crear la app en https://developers.mercadolibre.com.ar/devcenter
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://tu-dominio.com/api/ml/oauth/callback
ML_SELLER_ID=
# Se completan solos tras el primer login OAuth (ver /admin/marcas > MercadoLibre)
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Secreto para proteger los crons de sincronización (Vercel Cron llama con este header)
# Lo usan tanto /api/ml/sync como /api/instagram/sync
CRON_SECRET=cambia-este-valor

# ── Instagram (Instagram API with Instagram Login / Business Login) ─────
# Crear la app en https://developers.facebook.com/apps > agregar producto
# "API de Instagram" > usar el App ID/Secret de la sección "Configuración de
# la API con inicio de sesión de Instagram" (NO el App ID/Secret de Facebook).
IG_APP_ID=
IG_APP_SECRET=
IG_REDIRECT_URI=https://tu-dominio.com/api/instagram/oauth/callback
